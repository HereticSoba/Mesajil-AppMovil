<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="RoundedImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_medium</item>
    </style>

    <style name="CardRounded">
        <item name="cardCornerRadius">@dimen/corner_radius_medium</item>
        <item name="cardElevation">@dimen/card_elevation</item>
    </style>

    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_radius_small</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="ProductName">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_large</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="ProductPrice">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_large</item>
        <item name="android:textColor">@color/mesajil_blue</item>
    </style>

    <style name="ProductStock">
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textColor">@android:color/darker_gray</item>
    </style>

</resources>